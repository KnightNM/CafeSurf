# ── PostgreSQL Connection ──────────────────────────
# Local Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cafe_booking

# Use Supabase's direct or session-pooler URL for migrations and pg_dump/restore.
# Keep this separate when the deployed app uses a transaction-pooler URL.
# DATABASE_MIGRATION_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL=false

# Supabase/Postgres:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
# DATABASE_SSL=true

# ── Server ─────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Supabase Auth ─────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Server-only. Required only for admin bootstrap/demo Auth cleanup.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_INVITE_REDIRECT_URL=http://localhost:5173
