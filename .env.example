# ── PostgreSQL Connection ──────────────────────────
# Local Postgres:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cafe_booking
DATABASE_SSL=false

# Supabase/Postgres:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
# DATABASE_SSL=true

# ── Server ─────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Authentication ───────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
